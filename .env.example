# Prisma Database Connection (SQLite)
DATABASE_URL="file:./sp_essential/prisma/dev.db"

# NextAuth Configuration
NEXTAUTH_SECRET="your_nextauth_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Gemini API Key (for AI features)
GEMINI_API_KEY="your_gemini_api_key_here"

# Pinecone Vector DB (for RAG features)
PINECONE_API_KEY="your_pinecone_api_key_here"
PINECONE_INDEX_NAME="study-planner-index"

# OAuth Providers (Google, Kakao, Naver) - Optional for dev simulation
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"
KAKAO_CLIENT_ID="your_kakao_client_id_here"
KAKAO_CLIENT_SECRET="your_kakao_client_secret_here"
NAVER_CLIENT_ID="your_naver_client_id_here"
NAVER_CLIENT_SECRET="your_naver_client_secret_here"
